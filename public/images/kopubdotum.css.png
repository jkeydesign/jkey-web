@font-face {
	font-family: 'KoPubDotum';
	src: url('../fonts/subset/kopubdotum/KoPubDotum_subset.eot');
	src: local(※), url('../fonts/subset/kopubdotum/KoPubDotum_subset.eot?#iefix') format('embedded-opentype'),
	url('../fonts/subset/kopubdotum/KoPubDotum_subset.woff') format('woff'),
	url('../fonts/subset/kopubdotum/KoPubDotum_subset.woff2') format('woff2'),
	url('../fonts/subset/kopubdotum/KoPubDotum_subset.ttf') format('truetype');
	font-weight: normal;
	font-style: normal;
	font-display: swap;
}